package <%= entityAbsolutePackage %>.service.mapper;

<%_
  const getOriginalField = field => field.originalField || field;
  const uuidMapMethod = restProperties.some(property => property.relatedField?.fieldTypeUUID);
  /* Saathratri modification - include byte map method for vector fields (byte[] in entity, float[] in DTO) */
  const hasVectorFieldsInApp = typeof hasVectorFieldsSaathratri !== 'undefined' && hasVectorFieldsSaathratri;
  const byteMapMethod = restProperties.some(property => property.relatedField?.fieldTypeBytes) || hasVectorFieldsInApp;
  /* End Saathratri modification */
  const dtoRelationships = restProperties.filter(property => property.relationshipName && !property.otherEntity.embedded);
  /* Saathratri modification - entity graph directive parsing */
  const normalizeDirectives = value =>
    value === undefined || value === null
      ? []
      : (Array.isArray(value) ? value : [value]).flatMap(v =>
          typeof v === 'string' ? v.split('|').map(s => s.trim()).filter(Boolean) : [v],
        );
  const parseDirective = directive => {
    if (typeof directive !== 'string') return undefined;
    const [rawMethod, rawAttributes] = directive.split(':');
    const methodName = rawMethod?.trim();
    const attributePaths = (rawAttributes
      ?.replace(/^\s*\[\s*|\s*\]\s*$/g, '')
      ?.split(',')
      ?.map(attribute => attribute.trim())
      ?.filter(Boolean)) ?? [];
    if (methodName && attributePaths.length > 0) {
      return { methodName, attributePaths };
    }
    return undefined;
  };
  const entityGraphAnnotationValue = typeof entityGraph !== 'undefined' ? entityGraph : undefined;
  const entityGraphIncludeDirectives =
    typeof annotations !== 'undefined' ? normalizeDirectives(annotations.entityGraphIncludeCustomAnnotation) : [];
  const entityGraphExcludeDirectives =
    typeof annotations !== 'undefined' ? normalizeDirectives(annotations.entityGraphExcludeCustomAnnotation) : [];
  const entityGraphEntries = [
    ...normalizeDirectives(entityGraphAnnotationValue),
    ...entityGraphIncludeDirectives,
  ];
  const entityGraphDirectives = [];
  for (const directive of entityGraphEntries) {
    const parsedDirective = parseDirective(directive);
    if (parsedDirective) {
      entityGraphDirectives.push(parsedDirective);
    }
  }
  const dtoRelationshipNames = dtoRelationships.map(relationship => relationship.propertyName);
  for (const directive of entityGraphExcludeDirectives) {
    if (typeof directive !== 'string') continue;
    const [rawMethod, rawAttributes] = directive.split(':');
    const methodName = rawMethod?.trim();
    const excludedPaths = (rawAttributes
      ?.replace(/^\s*\[\s*|\s*\]\s*$/g, '')
      ?.split(',')
      ?.map(attribute => attribute.trim())
      ?.filter(Boolean)) ?? [];
    const attributePaths = dtoRelationshipNames.filter(propertyName => !excludedPaths.includes(propertyName));
    if (methodName && attributePaths.length > 0) {
      entityGraphDirectives.push({ methodName, attributePaths });
    }
  }
  const hasEntityGraphDirectives = entityGraphDirectives.length > 0;
  /* End Saathratri modification */
  let otherEntitiesFields = otherEntities
    .filter(otherEntity => dtoRelationships.some(relationship => relationship.otherEntity === otherEntity))
    .map(otherEntity =>
      dtoRelationships
        .filter(relationship => relationship.otherEntity == otherEntity)
        .map(({relatedField, collection}) => ({otherEntity, relatedField, collection}))
    )
    .flat();
  otherEntitiesFields.forEach(a => {
    a.collection = a.collection || otherEntitiesFields.some(b => a.otherEntity === b.otherEntity && getOriginalField(a.relatedField) === getOriginalField(b.relatedField) && b.collection === true)
  });
  otherEntitiesFields = this._.uniqWith(otherEntitiesFields, (a, b) => a.otherEntity === b.otherEntity && a.collection === b.collection && getOriginalField(a.relatedField) === getOriginalField(b.relatedField));
_%>

<%_ if (dtoRelationships.some(r => r.collection)) { _%>
import java.util.Set;
import java.util.stream.Collectors;
<%_ } _%>

import <%= entityAbsoluteClass %>;
import <%= entityAbsolutePackage %>.service.dto.<%= dtoClass %>;

<%_ for (const otherEntity of this._.uniq(dtoRelationships.map(relationship => relationship.otherEntity).filter(otherEntity => otherEntity.entityClass !== entityClass))) { _%>
import <%= otherEntity.entityAbsoluteClass %>;
import <%= otherEntity.entityAbsolutePackage %>.service.dto.<%= otherEntity.dtoClass %>;
<%_ } _%>

import org.mapstruct.*;
import org.mapstruct.control.NoComplexMapping; <%_ /* Saathratri modification - prevent infinite recursion with bidirectional relationships */ _%>
<%_ if (uuidMapMethod) { _%>

import java.util.Objects;
import java.util.UUID;
<%_ } _%>

/**
 * Mapper for the entity {@link <%= persistClass %>} and its DTO {@link <%= dtoClass %>}.
 *
 * Uses NoComplexMapping to prevent MapStruct from generating deep/complex mappings
 * that can cause infinite recursion with bidirectional entity relationships.
 * This limits MapStruct to direct field mappings only, requiring explicit @Mapping
 * annotations for any relationship mappings.
 */
<%_ /* Saathratri modification - NoComplexMapping to prevent infinite recursion */ _%>
@Mapper(componentModel = "spring", mappingControl = NoComplexMapping.class)
public interface <%= entityClass %>Mapper extends EntityMapper<<%= dtoClass %>, <%= persistClass %>> {
<%_ if (!embedded) { _%>
  <%_ var renMapAnotEnt = false; /*Render Mapping Annotation during Entity to DTO conversion?*/ _%>
  <%_ for (relationship of dtoRelationships) { _%>
    <%_
      renMapAnotEnt = true;
      let qualifiedByName = relationship.otherEntity.entityInstance + this._.upperFirst(relationship.otherEntityField);
      qualifiedByName = qualifiedByName + (relationship.collection ? 'Set' : '');
    _%>
    @Mapping(target = "<%= relationship.propertyName %>", source = "<%= relationship.propertyName %>", qualifiedByName="<%= qualifiedByName %>")
  <%_ } _%>
  <%_ /* Saathratri modification - exclude vector fields from mapstructExpression, add explicit vector @Mapping */ _%>
  <%_ for (const field of fields.filter(field => field.mapstructExpression && !field.fieldTypeVectorSaathratri)) {
      renMapAnotEnt = true; _%>
    @Mapping( target = "<%= field.propertyName %>", expression = "<%- field.mapstructExpression %>")
  <%_ } _%>
  <%_ const vectorFieldsForMapper = fields.filter(f => f.fieldTypeVectorSaathratri);
  if (vectorFieldsForMapper.length > 0) { renMapAnotEnt = true; } _%>
  <%_ /* End Saathratri modification */ _%>
  <%_ if (renMapAnotEnt || vectorFieldsForMapper.length > 0) { _%>
    <%= dtoClass %> toDto(<%= persistClass %> s);
  <%_ } _%>

  <%_ if (vectorFieldsForMapper.length > 0) { _%>
    <%_ /* Saathratri modification - this override adds the vector-field @Mapping(ignore) below, so it
          must re-state the base EntityMapper's @Named + null-ignore strategy; otherwise the override
          drops them and partial update overwrites required fields (e.g. name) with null. */ _%>
    @Named("partialUpdate")
    @BeanMapping(nullValuePropertyMappingStrategy = NullValuePropertyMappingStrategy.IGNORE)
  <%_ for (const vf of vectorFieldsForMapper) { _%>
    @Mapping(target = "<%= vf.propertyName %>", ignore = true)
  <%_ } _%>
    void partialUpdate(@MappingTarget <%= persistClass %> entity, <%= dtoClass %> dto);
  <%_ } _%>

  <%_ /* Saathratri modification - toDtoBasic lightweight mapper for list views */ _%>
  <%_
    const hasManyToManyRelationships = dtoRelationships.some(r => r.collection);
    if (hasManyToManyRelationships) {
      const manyToOneRelationships = dtoRelationships.filter(r => !r.collection);
      const manyToManyRelationships = dtoRelationships.filter(r => r.collection);
      const basicFields = fields.filter(field => !field.relationship);
  _%>

    /**
     * Lightweight mapper for list views that doesn't trigger lazy loading of collections.
     * Only maps basic fields and ManyToOne relationships, ignoring all ManyToMany collections.
     */
    @Named("toDtoBasic")
    @BeanMapping(ignoreByDefault = true)
  <%_ for (const field of basicFields) {
      if (field.mapstructExpression) { _%>
    @Mapping(target = "<%= field.propertyName %>", expression = "<%- field.mapstructExpression %>")
      <%_ } else { _%>
    @Mapping(target = "<%= field.propertyName %>", source = "<%= field.propertyName %>")
      <%_ } _%>
  <%_ } _%>
  <%_ for (relationship of manyToOneRelationships) {
      let qualifiedByName = relationship.otherEntity.entityInstance + this._.upperFirst(relationship.otherEntityField);
  _%>
    @Mapping(target = "<%= relationship.propertyName %>", source = "<%= relationship.propertyName %>", qualifiedByName = "<%= qualifiedByName %>")
  <%_ } _%>
  <%_ for (const manyToManyRel of manyToManyRelationships) { _%>
    @Mapping(target = "<%= manyToManyRel.propertyName %>", ignore = true)
  <%_ } _%>
    <%= dtoClass %> toDtoBasic(<%= persistClass %> <%= persistInstance %>);
  <%_ } _%>
  <%_ /* End Saathratri modification */ _%>

  <%_ var renMapAnotDto = false;  /*Render Mapping Annotation during DTO to Entity conversion?*/ _%>
  <%_ if(primaryKey.ids.length > 1) { _%>
    <%_ renMapAnotDto = true; _%>
    <%_ for (const id of primaryKey.ids) { _%>
    @Mapping(target = "id.<%= id.name %>", source = "<%= id.nameDotted %>")
    <%_ } _%>
  <%_ } _%>
  <%_ for (relationship of dtoRelationships) { _%>
    <%_ if (!relationship.ownerSide) { _%>
      <%_ renMapAnotDto = true; _%>
    @Mapping(target = "<%= relationship.propertyName %>", ignore = true)
    <%_ }
    if (relationship.collection && fluentMethods) {
      renMapAnotDto = true; _%>
    @Mapping(target = "remove<%= relationship.relationshipNameCapitalized %>", ignore = true)
    <%_ } _%>
  <%_ } _%>
  <%_ if (vectorFieldsForMapper.length > 0) { renMapAnotDto = true; } _%>
  <%_ if (renMapAnotDto) { _%>
  <%_ for (const vf of vectorFieldsForMapper) { _%>
    @Mapping(target = "<%= vf.propertyName %>", ignore = true)
  <%_ } _%>
    <%= persistClass %> toEntity(<%= dtoClass %> <%= dtoInstance %>);
  <%_ } _%>
  <%_ for (const {otherEntity, relatedField, collection} of otherEntitiesFields) { _%>
    <%_ const mapperName = otherEntity.entityInstance + this._.upperFirst(relatedField.propertyName); _%>

    @Named("<%= mapperName %>")
    @BeanMapping(ignoreByDefault = true)
    <%_ for (const field of otherEntity.primaryKey.fields) { _%>
    @Mapping(target = "<%= field.propertyName %>", source = "<%= field.propertyName %>")
    <%_ } _%>
    <%_ /* Saathratri modification - foreign key field mappers for GUI display */
      const guiDisplayFieldNames = [];
      if (isOptionToDisplayInGuiEnabled) {
        for (const f of (otherEntity.fields || []).filter(f => !f.hidden)) {
          if (f.options?.customAnnotation?.[0] === 'DISPLAY_IN_GUI_RELATIONSHIP_LINK') {
            guiDisplayFieldNames.push(f.fieldName);
          }
        }
    _%>
        <%- getMappingsToDisplayInMapper(otherEntity.fields) %>
    <%_
      }
    /* End Saathratri modification */ _%>
    <%_ if (!relatedField.id && !guiDisplayFieldNames.includes(relatedField.propertyName)) { _%>
      <%_ if (relatedField.mapstructExpression) { _%>
    @Mapping(target = "<%= relatedField.propertyName %>", expression = "<%- relatedField.mapstructExpression %>")
      <%_ } else { _%>
    @Mapping(target = "<%= relatedField.propertyName %>", source = "<%= relatedField.propertyName %>")
      <%_ } _%>
    <%_ } _%>
      <%_ if (relatedField.mapstructExpression) { _%>
    <%- otherEntity.dtoClass %> toDto<%= this._.upperFirst(mapperName) %>(<%- otherEntity.persistClass %> s);
    <%_ } else { _%>
    <%- otherEntity.dtoClass %> toDto<%= this._.upperFirst(mapperName) %>(<%- otherEntity.persistClass %> <%= otherEntity.persistInstance %>);
      <%_ } _%>
    <%_ if (collection) { %>
      <%_ const collectionMapperName = otherEntity.entityInstance + this._.upperFirst(relatedField.propertyName) + 'Set'; _%>

    @Named("<%= collectionMapperName %>")
    default Set<<%- otherEntity.dtoClass %>> toDto<%= this._.upperFirst(mapperName) %>Set(Set<<%- otherEntity.persistClass %>> <%= otherEntity.persistInstance %>) {
        return <%= otherEntity.persistInstance %>.stream().map(this:: toDto<%= this._.upperFirst(mapperName) %>).collect(Collectors.toSet());
    }
    <%_ } _%>
  <%_ } _%>
  <%_ /* Saathratri modification - entity graph query mapper methods */ _%>
  <%_ if (hasEntityGraphDirectives) { _%>

    <%_ for (const entityGraphQuery of entityGraphDirectives) { _%>
      @Named("to<%= this._.upperFirst(entityGraphQuery.methodName) %>")
      @BeanMapping(ignoreByDefault = true)
    <%_ for (const field of fields.filter(field => !field.relationship)) { _%>
      <%_ if (field.mapstructExpression) { _%>
      @Mapping(target = "<%= field.propertyName %>", expression = "<%- field.mapstructExpression %>")
      <%_ } else { _%>
      @Mapping(target = "<%= field.propertyName %>", source = "<%= field.propertyName %>")
      <%_ } _%>
    <%_ } _%>
    <%_ for (const relationship of dtoRelationships) { _%>
      <%_ if (entityGraphQuery.attributePaths.includes(relationship.propertyName)) { _%>
        <%_ const qualifiedByName = relationship.otherEntity.entityInstance + this._.upperFirst(relationship.otherEntityField) + (relationship.collection ? 'Set' : ''); _%>
      @Mapping(target = "<%= relationship.propertyName %>", source = "<%= relationship.propertyName %>", qualifiedByName = "<%= qualifiedByName %>")
      <%_ } else { _%>
      @Mapping(target = "<%= relationship.propertyName %>", ignore = true)
      <%_ } _%>
    <%_ } _%>
      <%= dtoClass %> to<%= this._.upperFirst(entityGraphQuery.methodName) %>(<%= persistClass %> <%= persistInstance %>);
    <%_ } _%>
  <%_ } _%>
  <%_ /* End Saathratri modification */ _%>
  <%_ if (uuidMapMethod) { _%>

    default String map(UUID value) {
        return Objects.toString(value, null);
    }
  <%_ } _%>
  <%_ /* Saathratri modification - null-safe byte mapping with reverse String->byte[] */ _%>
  <%_ if (byteMapMethod) { _%>

    default String map(byte[] value) {
        return value == null ? null : new String(value);
    }

    default byte[] map(String value) {
        return value == null ? null : value.getBytes();
    }
  <%_ } _%>
  <%_ /* End Saathratri modification */ _%>
  <%_ if (fields.some(f => f.fieldTypeVectorSaathratri)) { _%>

    default java.util.List<Float> mapFloatArrayToList(float[] array) {
        if (array == null) { return null; }
        java.util.List<Float> list = new java.util.ArrayList<>(array.length);
        for (float f : array) {
            list.add(f);
        }
        return list;
    }
  <%_ } _%>
<%_ } _%>
}
