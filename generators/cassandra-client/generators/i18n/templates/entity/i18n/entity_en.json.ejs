{
    "<%= frontendAppName %>": {
        "<%= entityTranslationKey %>" : {
            "home": {
                "title": "<%= entityNamePluralHumanized %>",
                "refreshListLabel": "Refresh list",
<%_ if (!readOnly) { _%>
                "createLabel": "Create a new <%= entityNameHumanized %>",
                "createOrEditLabel": "Create or edit a <%= entityNameHumanized %>",
<%_ } _%>
<%_ if (locals.searchEngineAny) { _%>
                "search": "Search for <%= entityNameHumanized %>",
<%_ } _%>
                "notFound": "No <%= entityNamePluralHumanized %> found"<%# Saathratri change: Cassandra cursor-based paging needs loadMore/endOfList labels (upstream removed paginationInfiniteScroll block in 9.0.0) %><%_ if (paginationInfiniteScroll || (databaseTypeCassandra && paginationNo)) { _%>,
                "loadMore": "Load More",
                "loadingMore": "Loading more <%= entityNamePluralHumanized.toLowerCase() %>...",
                "endOfList": "You've reached the end of the list"<%_ } _%><%# Saathratri change: composite key search UI labels for partition/clustering key search form (upstream has no composite key support) %><%_ if (databaseTypeCassandra && primaryKeySaathratri.composite) { _%>,
                "search": "Search <%= entityNamePluralHumanized %>",
                "searchActive": "Search Active",
                "searchRequired": "Enter partition key values above and click Search to load data",
                "partitionKeys": "Partition Keys",
                "clusteringKeys": "Clustering Keys",
                "optional": "optional",
                "operator": "Operator",
                "selectDate": "Select Date",
                "hour": "Hour",
                "minute": "Minute",
                "dateFormat": "Format: 9 Dec 2025",
                "dateTimeFormat": "Format: 9 Dec 2025, 14:30:00",
                "searchButton": "Search",
                "clearSearch": "Clear"<%_ } _%>
            },
<%_ if (!microserviceAppName && !readOnly) { _%>
            "created": "A new <%= entityNameHumanized %> is created with identifier {{ param }}",
            "updated": "A <%= entityNameHumanized %> is updated with identifier {{ param }}",
            "deleted": "A <%= entityNameHumanized %> is deleted with identifier {{ param }}",
<%_ } _%>
<%_ if (!readOnly) { _%>
            "delete": {
<%# Saathratri change: composite key delete confirmation uses getCompositePrimaryKeyConfirmDelete() to list all key fields (upstream uses simple {{ id }}) #%>
            <%_
                // Composite Primary Key Code
                if (primaryKeySaathratri.composite) {
            _%>
            "question": "Are you sure you want to delete <%= entityNameHumanized %> <%- getCompositePrimaryKeyConfirmDelete(primaryKeySaathratri) %>?"
            <%_
                // Single-value Primary Key Code
                } else {
            _%>
                "question": "Are you sure you want to delete <%= entityNameHumanized %> {{ id }}?"
            <%_ } _%>                
            },
<%_ } _%>
            "detail": {
                "title": "<%= entityNameHumanized %>"
            }
<%_ for (const field of fields) { -%>
            ,
            "<%= field.fieldName %>": "<%= field.fieldNameHumanized %>"
<%_ } -%>
<% for (const relationship of relationships) { -%>
            ,
            "<%= relationship.relationshipName %>": "<%= relationship.relationshipNameHumanized %>"
<%_ } -%>
<%_ const fieldsWithDoc = fields.filter(field => field.documentation); -%>
<%_ if (fieldsWithDoc.length > 0) { -%>
  <%_ const lastField = fieldsWithDoc[fieldsWithDoc.length - 1]; -%>
            ,
            "help": {
  <%_ for (const field of fieldsWithDoc) { _%>
                "<%= field.fieldName %>": "<%= field.documentation %>"<% if (field !== lastField) { %>,<% } %>
  <%_ } _%>
            }
<%_ } _%>
        }
    }
<%_ if (microserviceAppName && !readOnly) { -%>
    ,
    "<%= microserviceAppName %>": {
        "<%= entityTranslationKey %>" : {
            "created": "A new <%= entityNameHumanized %> is created with identifier {{ param }}",
            "updated": "A <%= entityNameHumanized %> is updated with identifier {{ param }}",
            "deleted": "A <%= entityNameHumanized %> is deleted with identifier {{ param }}"
        }
    }
<%_ } _%>
}
