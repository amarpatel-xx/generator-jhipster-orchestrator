<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

<%_ for (const idx of customQueryIndexes) { _%>
    <changeSet id="<%= changelogDate %>-custom-idx-<%= idx.methodName %>" author="jhipster">
        <createIndex indexName="<%= idx.indexName %>" tableName="<%= idx.tableName || entityTableName %>">
<%_ for (const col of idx.columnNames) { _%>
            <column name="<%= col %>"/>
<%_ } _%>
        </createIndex>
    </changeSet>
<%_ } _%>

</databaseChangeLog>
