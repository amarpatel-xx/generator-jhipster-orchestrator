  // Service spec matching the blueprint service API. Composite: find(<each key field>),
  // delete(entity), compare(Pick<I,'compositeId'>). Single-key: find(id), delete(id),
  // compare(Pick<I,'id'>). find() args use type-appropriate literals (the find params follow
  // the raw key type — number for Long keys even when the model exposes them as dayjs).
  const composite = primaryKeySaathratri.composite;
  const findLiteral = name => {
    const f = fields.find(ff => ff.fieldName === name);
    return f && f.tsType === 'number' ? '1' : `'${name}'`;
  };
  const findArgs = composite ? primaryKeySaathratri.ids.map(id => findLiteral(id.fieldName)).join(', ') : findLiteral(primaryKey.name);
  const deleteArg = composite ? 'sampleWithRequiredData' : `sampleWithRequiredData.${primaryKey.name}`;
  const cmp = sample => (composite ? `{ compositeId: ${sample}.compositeId }` : `{ ${primaryKey.name}: ${sample}.${primaryKey.name} }`);

  // Mirror service.ts.ejs's composite-key search-method generation so each generated method gets a
  // spec: progressive partition/clustering-key prefixes (findAllBy...Pageable), clustering comparison
  // operators, and the full-key findBy. Kept in lockstep with the same iteration the service uses.
  const searchMethods = [];
  if (composite) {
    const pkFields = primaryKeySaathratri.ids;
    const keyName = primaryKeySaathratri.nameCapitalized;
    for (let i = 0; i < pkFields.length; i++) {
      const parts = [], args = [];
      for (let j = 0; j <= i; j++) { parts.push(`${keyName}${pkFields[j].fieldNameCapitalized}`); args.push(findLiteral(pkFields[j].fieldName)); }
      searchMethods.push({ name: 'findAllBy' + parts.join('And') + 'Pageable', args: args.join(', '), single: false });
    }
    for (let i = 0; i < pkFields.length; i++) {
      const cf = pkFields[i];
      if (!cf.isClusteredKeySaathratri || (cf.fieldType !== 'Long' && !cf.fieldTypeTimeUuidSaathratri)) continue;
      const parts = [], args = [];
      for (let j = 0; j <= i; j++) { parts.push(`${keyName}${pkFields[j].fieldNameCapitalized}`); args.push(findLiteral(pkFields[j].fieldName)); }
      const base = parts.join('And');
      for (const op of ['LessThan', 'LessThanEqual', 'GreaterThan', 'GreaterThanEqual']) {
        searchMethods.push({ name: `findAllBy${base}${op}Pageable`, args: args.join(', '), single: false });
      }
    }
    const allParts = [], allArgs = [];
    for (const f of pkFields) { allParts.push(`${keyName}${f.fieldNameCapitalized}`); allArgs.push(findLiteral(f.fieldName)); }
    searchMethods.push({ name: 'findBy' + allParts.join('And'), args: allArgs.join(', '), single: true });
  }
