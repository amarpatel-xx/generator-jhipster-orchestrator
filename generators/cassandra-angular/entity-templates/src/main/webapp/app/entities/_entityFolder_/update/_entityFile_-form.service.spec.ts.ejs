<%_
  // Form-service spec matching the blueprint form. Composite entities nest the key fields under
  // a `compositeId` FormGroup; single-key entities have a flat key control. getX() uses
  // getRawValue() and resetForm() always disables the key control(s). Assertions match that.
  const composite = primaryKeySaathratri.composite;
  const keyFieldNames = composite ? primaryKeySaathratri.ids.map(f => f.fieldName) : [primaryKey.name];
  const nonKeyFormFields = fields.filter(f => !keyFieldNames.includes(f.fieldName) && !f.fieldTypeVectorSaathratri);
  const firstKey = keyFieldNames[0];
  const keyControlEntry = composite ? 'compositeId: expect.any(Object)' : `${firstKey}: expect.any(Object)`;
  const keyControlPath = composite ? `compositeId.controls.${firstKey}` : firstKey;
  const resetArg = composite ? `{ compositeId: { ${keyFieldNames.map(n => `${n}: null`).join(', ')} } }` : 'sampleWithRequiredData';
_%>
import { beforeEach, describe, expect, it } from 'vitest';
import { TestBed } from '@angular/core/testing';

import { sampleWithNewData, sampleWithRequiredData } from '../<%= entityFileName %>.test-samples';

import { <%= entityAngularName %>FormService } from './<%= entityFileName %>-form.service';

describe('<%= entityAngularName %> Form Service', () => {
  let service: <%= entityAngularName %>FormService;

  beforeEach(() => {
    service = TestBed.inject(<%= entityAngularName %>FormService);
  });

  describe('Service methods', () => {
    describe('create<%= entityAngularName %>FormGroup', () => {
      it('should create a new form with FormControl', () => {
        const formGroup = service.create<%= entityAngularName %>FormGroup();

        expect(formGroup.controls).toEqual(
          expect.objectContaining({
            <%- keyControlEntry %>,
<%_ nonKeyFormFields.forEach(f => { _%>
            <%= f.fieldName %>: expect.any(Object),
<%_ }); _%>
          }),
        );
      });

      it('passing I<%= entityAngularName %> should create a new form with FormGroup', () => {
        const formGroup = service.create<%= entityAngularName %>FormGroup(sampleWithRequiredData);

        expect(formGroup.controls).toEqual(
          expect.objectContaining({
            <%- keyControlEntry %>,
<%_ nonKeyFormFields.forEach(f => { _%>
            <%= f.fieldName %>: expect.any(Object),
<%_ }); _%>
          }),
        );
      });
    });

    describe('get<%= entityAngularName %>', () => {
      it('should return New<%= entityAngularName %> for default <%= entityAngularName %> initial value', () => {
        const formGroup = service.create<%= entityAngularName %>FormGroup(sampleWithNewData);

        const <%= entityInstance %> = service.get<%= entityAngularName %>(formGroup);

        expect(<%= entityInstance %>).toMatchObject(sampleWithNewData);
      });

      it('should return New<%= entityAngularName %> for empty <%= entityAngularName %> initial value', () => {
        const formGroup = service.create<%= entityAngularName %>FormGroup();

        const <%= entityInstance %> = service.get<%= entityAngularName %>(formGroup);

        expect(<%= entityInstance %>).toMatchObject({});
      });

      it('should return I<%= entityAngularName %>', () => {
        const formGroup = service.create<%= entityAngularName %>FormGroup(sampleWithRequiredData);

        const <%= entityInstance %> = service.get<%= entityAngularName %>(formGroup);

        expect(<%= entityInstance %>).toMatchObject(sampleWithRequiredData);
      });
    });

    describe('resetForm', () => {
      it('passing I<%= entityAngularName %> should keep the key control disabled', () => {
        const formGroup = service.create<%= entityAngularName %>FormGroup(sampleWithRequiredData);
        expect(formGroup.controls.<%- keyControlPath %>.disabled).toBe(true);

        service.resetForm(formGroup, sampleWithRequiredData);

        expect(formGroup.controls.<%- keyControlPath %>.disabled).toBe(true);
      });

      it('resetForm disables the key control even for a new entity', () => {
        const formGroup = service.create<%= entityAngularName %>FormGroup();

        service.resetForm(formGroup, <%- resetArg %>);

        expect(formGroup.controls.<%- keyControlPath %>.disabled).toBe(true);
      });
    });
  });
});
