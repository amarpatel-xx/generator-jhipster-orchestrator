{
  "name": "generator-jhipster-orchestrator",
  "version": "1.0.6",
  "description": "Master JHipster blueprint that orchestrates SQL/pgvector and Cassandra blueprints into a multi-database microservices platform",
  "keywords": [
    "yeoman-generator",
    "jhipster-blueprint",
    "orchestrator",
    "microservices",
    "cassandra",
    "pgvector",
    "jhipster"
  ],
  "author": "Amar Premsaran Patel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amarpatel-xx/generator-jhipster-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/amarpatel-xx/generator-jhipster-orchestrator/issues"
  },
  "homepage": "https://github.com/amarpatel-xx/generator-jhipster-orchestrator#readme",
  "type": "module",
  "bin": {
    "jhipster-orchestrator": "cli/cli.cjs"
  },
  "files": [
    "cli",
    "generators"
  ],
  "scripts": {
    "ejslint": "ejslint generators/**/*.ejs",
    "lint": "eslint .",
    "lint-fix": "npm run ejslint && npm run lint -- --fix",
    "prepare": "husky",
    "prettier-check": "prettier --check \"{,**/}*.{md,json,yml,html,js,ts,tsx,css,scss,vue,java}\"",
    "prettier-format": "prettier --write \"{,**/}*.{md,json,yml,html,js,ts,tsx,css,scss,vue,java}\"",
    "pretest": "npm run prettier-check && npm run lint",
    "test": "vitest run",
    "update-snapshot": "vitest run --update",
    "vitest": "vitest"
  },
  "dependencies": {
    "generator-jhipster": "9.1.0",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "ejs-lint": "2.0.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "husky": "^9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "11.0.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.4",
    "yeoman-test": ">=8.0.0-rc.1"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "cacheDirectories": [
    "node_modules"
  ]
}
